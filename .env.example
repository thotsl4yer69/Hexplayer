# HexPlayer environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Spotify API credentials ────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Redirect URI registered in your Spotify app settings
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ── Raspotify / Spotify Connect ───────────────────────────────────────────────
# Name this device will show as in Spotify Connect
DEVICE_NAME=HexPlayer

# Spotify Connect device ID (leave blank to auto-detect the Raspotify device)
# You can find this by running: python3 -c "from hexplayer import get_device_id; print(get_device_id())"
DEVICE_ID=

# ── NFC reader ────────────────────────────────────────────────────────────────
# SPI bus and chip-select for the RC522 reader
NFC_SPI_BUS=0
NFC_SPI_DEVICE=0

# GPIO pin (BCM numbering) used as the RC522 reset line
NFC_RESET_PIN=25

# ── Playback ──────────────────────────────────────────────────────────────────
# Seconds before the same tile can trigger playback again (anti-bounce)
DEBOUNCE_SECONDS=3

# Seconds to wait between polling loops when no card is present
POLL_INTERVAL=0.2

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
